# --- required ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# --- Discord bot (Phase 2) ---
# The bot is permanently read-only: it watches tickets, drafts a suggested
# reply, and shows it on the Support tab -- it never posts back to Discord
# (only 👀/✅ reactions). See discord_bot/bot.py.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# One role id, or several comma-separated (e.g. Moderator + Staff Volunteer roles).
DISCORD_STAFF_ROLE_ID=
DISCORD_ESCALATION_CHANNEL_ID=
# Category id that ticket channels live under (e.g. Ticket King's ticket category).
# The bot watches any channel/thread under this category, plus DMs.
DISCORD_TICKETS_CATEGORY_ID=

# --- Freshdesk (KB bootstrap source) ---
FRESHDESK_DOMAIN=your-subdomain
FRESHDESK_API_KEY=

# --- Dashboard auth (Phase 3) ---
DASHBOARD_PASSWORD=change-me

# --- storage ---
DB_PATH=./data/supportbot.db

# --- misc ---
# Random 32+ char string used to sign web-widget session cookies.
SECRET_KEY=change-me-to-a-random-64-hex-char-string
